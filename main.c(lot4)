#include <SDL2/SDL.h>
#include <SDL2/SDL_image.h>
#include <stdio.h>
#include <stdlib.h>
#include <time.h>
#include "minimap.h"

typedef struct {
    SDL_Texture* gameBg;
    SDL_Surface* maskSurf;
    SDL_Texture* miniBg;
} Level;


int CollisionBB(SDL_Rect a, SDL_Rect b) {
    return !(b.x > a.x + a.w || b.x + b.w < a.x || b.y > a.y + a.h || b.y + b.h < a.y);
}


SDL_Color GetPixel(SDL_Surface *surface, int x, int y) {
    SDL_Color color = {255, 255, 255, 255};
    if (x < 0 || y < 0 || x >= surface->w || y >= surface->h) return color;
    Uint32 *pixels = (Uint32*)surface->pixels;
    Uint32 pixel = pixels[y * surface->w + x];
    SDL_GetRGB(pixel, surface->format, &color.r, &color.g, &color.b);
    return color;
}


int CollisionParfaite(SDL_Surface *mask, SDL_Rect p) {
    SDL_Color c;
    int points[3][2] = {
        {p.x + 10, p.y + p.h - 5},
        {p.x + p.w/2, p.y + p.h - 5},
        {p.x + p.w - 10, p.y + p.h - 5}
    };
    for(int i=0; i<3; i++) {
        c = GetPixel(mask, points[i][0], points[i][1]);
        if(c.r < 20 && c.g < 20 && c.b < 20) return 1;
    }
    return 0;
}

int main() {
    srand(time(NULL));
    SDL_Init(SDL_INIT_VIDEO);
    IMG_Init(IMG_INIT_PNG);

    SDL_Window* window = SDL_CreateWindow("Game Integration Levels", SDL_WINDOWPOS_CENTERED, SDL_WINDOWPOS_CENTERED, 800, 600, 0);
    SDL_Renderer* renderer = SDL_CreateRenderer(window, -1, SDL_RENDERER_ACCELERATED);

   
    Level lvl1;
    SDL_Surface* s1 = IMG_Load("background_minimap.png");
    lvl1.gameBg = SDL_CreateTextureFromSurface(renderer, s1);
    lvl1.miniBg = lvl1.gameBg; 
    SDL_FreeSurface(s1);
    SDL_Surface* m1 = SDL_LoadBMP("backgroundMasque1.bmp");
    lvl1.maskSurf = SDL_ConvertSurfaceFormat(m1, SDL_PIXELFORMAT_ARGB8888, 0);
    SDL_FreeSurface(m1);

    
    Level lvl2;
    SDL_Surface* s2 = IMG_Load("background.png");
    lvl2.gameBg = SDL_CreateTextureFromSurface(renderer, s2);
    lvl2.miniBg = lvl2.gameBg;
    SDL_FreeSurface(s2);
    SDL_Surface* m2 = SDL_LoadBMP("backgroundMasque2.bmp");
    lvl2.maskSurf = SDL_ConvertSurfaceFormat(m2, SDL_PIXELFORMAT_ARGB8888, 0);
    SDL_FreeSurface(m2);

    
    SDL_Surface* pSurf = IMG_Load("player_point.png");
    SDL_Texture* playerTex = SDL_CreateTextureFromSurface(renderer, pSurf);
    SDL_Texture* pointTex = SDL_CreateTextureFromSurface(renderer, pSurf);
    SDL_FreeSurface(pSurf);


    SDL_Rect posLvl1 = {100, 450, 50, 50}; // Position pour le Niveau 1
    SDL_Rect posLvl2 = {100, 450, 50, 50}; // Position pour le Niveau 2 

    SDL_Rect obstacle = {300, 400, 100, 100};
    
    Minimap m;
    m.pointTexture = pointTex;
    m.minimapPosition = (SDL_Rect){600, 20, 180, 180};
    float scaleX = 180.0f / 800.0f;
    float scaleY = 180.0f / 600.0f;

    int currentLevel = 1;
    int running = 1;
    SDL_Event event;
    int shake = 0, shakeTimer = 0;

    while(running) {
        while(SDL_PollEvent(&event)) {
            if(event.type == SDL_QUIT) running = 0;
            if(event.type == SDL_KEYDOWN) {
                if(event.key.keysym.sym == SDLK_1) currentLevel = 1;
                if(event.key.keysym.sym == SDLK_2) currentLevel = 2;
            }
        }

        
        Level* active = (currentLevel == 1) ? &lvl1 : &lvl2;
        SDL_Rect* activePos = (currentLevel == 1) ? &posLvl1 : &posLvl2;
        
        m.backgroundTexture = active->miniBg;

        const Uint8* state = SDL_GetKeyboardState(NULL);
        SDL_Rect nextPos = *activePos; 
        
        int speed = 5;
        if(state[SDL_SCANCODE_RIGHT]) nextPos.x += speed;
        if(state[SDL_SCANCODE_LEFT])  nextPos.x -= speed;
        if(state[SDL_SCANCODE_UP])    nextPos.y -= speed;
        if(state[SDL_SCANCODE_DOWN])  nextPos.y += speed;

        
        if(nextPos.x < 0) nextPos.x = 0; 
        if(nextPos.y < 0) nextPos.y = 0;
        if(nextPos.x > 750) nextPos.x = 750; 
        if(nextPos.y > 550) nextPos.y = 550;

        
        if(CollisionParfaite(active->maskSurf, nextPos) || CollisionBB(nextPos, obstacle)) {
            shake = 1; 
            shakeTimer = 10;
        } else {
            *activePos = nextPos; 
        }

        
        MAJMinimap(*activePos, obstacle, &m, scaleX, scaleY);

        
        SDL_SetRenderDrawColor(renderer, 0, 0, 0, 255);
        SDL_RenderClear(renderer);

        SDL_Rect bgAnim = {0, 0, 800, 600};
        SDL_Rect miniAnim = m.minimapPosition;
        SDL_Rect pMiniAnim = m.pointPosition;
        SDL_Rect obsMiniAnim = m.obstacleMini;

        if(shake) {
            int dx = rand()%5 - 2; 
            int dy = rand()%5 - 2;
            bgAnim.x += dx; bgAnim.y += dy;
            miniAnim.x += dx; miniAnim.y += dy;
            pMiniAnim.x += dx; pMiniAnim.y += dy;
            obsMiniAnim.x += dx; obsMiniAnim.y += dy;
            shakeTimer--;
            if(shakeTimer <= 0) shake = 0;
        }

        
        SDL_RenderCopy(renderer, active->gameBg, NULL, &bgAnim);
        SDL_SetRenderDrawColor(renderer, 255, 255, 255, 255);
        SDL_RenderFillRect(renderer, &obstacle);
        SDL_RenderCopy(renderer, playerTex, NULL, activePos);

        
        SDL_RenderCopy(renderer, m.backgroundTexture, NULL, &miniAnim);
        SDL_SetRenderDrawColor(renderer, 255, 255, 255, 255);
        SDL_RenderFillRect(renderer, &obsMiniAnim);
        SDL_RenderCopy(renderer, m.pointTexture, NULL, &pMiniAnim);

        SDL_RenderPresent(renderer);
        SDL_Delay(16);
    }

    
    SDL_FreeSurface(lvl1.maskSurf); SDL_DestroyTexture(lvl1.gameBg);
    SDL_FreeSurface(lvl2.maskSurf); SDL_DestroyTexture(lvl2.gameBg);
    SDL_DestroyTexture(playerTex);
    SDL_DestroyTexture(pointTex);
    SDL_DestroyRenderer(renderer);
    SDL_DestroyWindow(window);
    IMG_Quit(); SDL_Quit();
    
    return 0;
}
