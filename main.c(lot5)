#include "quiz.h"
#include <SDL2/SDL.h>
#include <SDL2/SDL_ttf.h>
#include <SDL2/SDL_mixer.h>
#include <stdio.h>
#include <stdlib.h>
#include <time.h>

int main(void)
{
    SDL_Window *window;
    SDL_Renderer *renderer;
    SDL_Surface *surface;
    SDL_Texture *background;
    TTF_Font *font;
    Mix_Music *musiqueFond;
    Mix_Chunk *sonCorrect;
    Mix_Chunk *sonFaux;
    Mix_Chunk *sonBouton;
    SDL_Event event;
    Enigme enigme;
    int continuer;
    int mode;
    int score;
    int vies;
    int choix;
    int tempsRestant;
    int x;
    int y;
    Uint32 debut;

    srand((unsigned int)time(NULL));
    continuer = 1;
    mode = 0;
    score = 3;
    vies = 3;
    choix = 0;
    tempsRestant = TEMPS_ENIGME;
    window = NULL;
    renderer = NULL;
    surface = NULL;
    background = NULL;
    font = NULL;
    musiqueFond = NULL;
    sonCorrect = NULL;
    sonFaux = NULL;
    sonBouton = NULL;

    if (SDL_Init(SDL_INIT_VIDEO | SDL_INIT_AUDIO) != 0) return 1;
    if (TTF_Init() != 0)
    {
        SDL_Quit();
        return 1;
    }
    if (Mix_OpenAudio(44100, MIX_DEFAULT_FORMAT, 2, 2048) < 0)
    {
        TTF_Quit();
        SDL_Quit();
        return 1;
    }

    window = SDL_CreateWindow("Enigme aleatoire", SDL_WINDOWPOS_CENTERED, SDL_WINDOWPOS_CENTERED, 800, 640, 0);
    if (window == NULL)
    {
        Mix_CloseAudio();
        TTF_Quit();
        SDL_Quit();
        return 1;
    }

    renderer = SDL_CreateRenderer(window, -1, SDL_RENDERER_ACCELERATED | SDL_RENDERER_PRESENTVSYNC);
    if (renderer == NULL)
    {
        SDL_DestroyWindow(window);
        Mix_CloseAudio();
        TTF_Quit();
        SDL_Quit();
        return 1;
    }

    font = chargerPolice(24);
    if (font == NULL)
    {
        SDL_DestroyRenderer(renderer);
        SDL_DestroyWindow(window);
        Mix_CloseAudio();
        TTF_Quit();
        SDL_Quit();
        return 1;
    }

    surface = SDL_LoadBMP("assets/background.bmp");
    if (surface != NULL)
    {
        background = SDL_CreateTextureFromSurface(renderer, surface);
        SDL_FreeSurface(surface);
    }

    musiqueFond = Mix_LoadMUS("assets/background.wav");
    sonCorrect = Mix_LoadWAV("assets/correct.wav");
    sonFaux = Mix_LoadWAV("assets/wrong.wav");
    sonBouton = Mix_LoadWAV("assets/button.wav");

    if (musiqueFond != NULL)
    {
        Mix_VolumeMusic(48);
        Mix_PlayMusic(musiqueFond, -1);
    }
    if (sonCorrect != NULL) Mix_VolumeChunk(sonCorrect, 96);
    if (sonFaux != NULL) Mix_VolumeChunk(sonFaux, 96);
    if (sonBouton != NULL) Mix_VolumeChunk(sonBouton, 96);

    enigme = generer("questions.txt");
    debut = SDL_GetTicks();

    while (continuer)
    {
        while (SDL_PollEvent(&event))
        {
            if (event.type == SDL_QUIT) continuer = 0;
            if (event.type == SDL_KEYDOWN)
            {
                if (event.key.keysym.sym == SDLK_ESCAPE) continuer = 0;
                if (mode == 0 && event.key.keysym.sym == SDLK_RETURN)
                {
                    if (sonBouton != NULL) Mix_PlayChannel(-1, sonBouton, 0);
                    mode = 1;
                    debut = SDL_GetTicks();
                }
                else if (mode == 1)
                {
                    if (event.key.keysym.sym == SDLK_1) choix = 1;
                    else if (event.key.keysym.sym == SDLK_2) choix = 2;
                    else if (event.key.keysym.sym == SDLK_3) choix = 3;
                }
            }
            if (event.type == SDL_MOUSEBUTTONDOWN && event.button.button == SDL_BUTTON_LEFT)
            {
                x = event.button.x;
                y = event.button.y;
                if (mode == 0)
                {
                    if (x >= enigme.posStart.x && x <= enigme.posStart.x + enigme.posStart.w && y >= enigme.posStart.y && y <= enigme.posStart.y + enigme.posStart.h)
                    {
                        if (sonBouton != NULL) Mix_PlayChannel(-1, sonBouton, 0);
                        mode = 1;
                        debut = SDL_GetTicks();
                    }
                    else if (x >= enigme.posQuit.x && x <= enigme.posQuit.x + enigme.posQuit.w && y >= enigme.posQuit.y && y <= enigme.posQuit.y + enigme.posQuit.h)
                    {
                        if (sonBouton != NULL) Mix_PlayChannel(-1, sonBouton, 0);
                        continuer = 0;
                    }
                }
                else if (mode == 1)
                {
                    if (x >= enigme.posRep1.x && x <= enigme.posRep1.x + enigme.posRep1.w && y >= enigme.posRep1.y && y <= enigme.posRep1.y + enigme.posRep1.h)
                    {
                        if (sonBouton != NULL) Mix_PlayChannel(-1, sonBouton, 0);
                        choix = 1;
                    }
                    else if (x >= enigme.posRep2.x && x <= enigme.posRep2.x + enigme.posRep2.w && y >= enigme.posRep2.y && y <= enigme.posRep2.y + enigme.posRep2.h)
                    {
                        if (sonBouton != NULL) Mix_PlayChannel(-1, sonBouton, 0);
                        choix = 2;
                    }
                    else if (x >= enigme.posRep3.x && x <= enigme.posRep3.x + enigme.posRep3.w && y >= enigme.posRep3.y && y <= enigme.posRep3.y + enigme.posRep3.h)
                    {
                        if (sonBouton != NULL) Mix_PlayChannel(-1, sonBouton, 0);
                        choix = 3;
                    }
                }
            }
        }

        if (mode == 1)
        {
            tempsRestant = TEMPS_ENIGME - (int)((SDL_GetTicks() - debut) / 1000);
            if (tempsRestant < 0) tempsRestant = 0;

            if (choix != 0)
            {
                if (choix == enigme.numbr)
                {
                    if (sonCorrect != NULL) Mix_PlayChannel(-1, sonCorrect, 0);
                    score = score + 1;
                    enigme.etat = 1;
                    afficherEcran(renderer, font, background, enigme, 2, score, vies, tempsRestant, "Bonne reponse");
                    SDL_RenderPresent(renderer);
                    SDL_Delay(1200);
                }
                else
                {
                    if (sonFaux != NULL) Mix_PlayChannel(-1, sonFaux, 0);
                    score = score - 1;
                    vies = vies - 1;
                    enigme.etat = -1;
                    afficherEcran(renderer, font, background, enigme, 3, score, vies, tempsRestant, "Mauvaise reponse");
                    SDL_RenderPresent(renderer);
                    SDL_Delay(1200);
                }
                choix = 0;
                if (vies > 0 && score > 0)
                {
                    enigme = generer("questions.txt");
                    debut = SDL_GetTicks();
                    mode = 1;
                }
                else
                    continuer = 0;
            }
            else if (tempsRestant == 0)
            {
                if (sonFaux != NULL) Mix_PlayChannel(-1, sonFaux, 0);
                score = score - 1;
                vies = vies - 1;
                enigme.etat = -1;
                afficherEcran(renderer, font, background, enigme, 3, score, vies, tempsRestant, "Temps ecoule");
                SDL_RenderPresent(renderer);
                SDL_Delay(1200);
                if (vies > 0 && score > 0)
                {
                    enigme = generer("questions.txt");
                    debut = SDL_GetTicks();
                }
                else
                    continuer = 0;
            }
        }

        if (mode == 0) afficherEcran(renderer, font, background, enigme, 0, score, vies, tempsRestant, "");
        else if (mode == 1) afficherEcran(renderer, font, background, enigme, 1, score, vies, tempsRestant, "");
        SDL_RenderPresent(renderer);
    }

    if (musiqueFond != NULL) Mix_HaltMusic();
    if (sonBouton != NULL) Mix_FreeChunk(sonBouton);
    if (sonFaux != NULL) Mix_FreeChunk(sonFaux);
    if (sonCorrect != NULL) Mix_FreeChunk(sonCorrect);
    if (musiqueFond != NULL) Mix_FreeMusic(musiqueFond);
    if (background != NULL) SDL_DestroyTexture(background);
    if (font != NULL) TTF_CloseFont(font);
    if (renderer != NULL) SDL_DestroyRenderer(renderer);
    if (window != NULL) SDL_DestroyWindow(window);
    Mix_CloseAudio();
    TTF_Quit();
    SDL_Quit();
    return 0;
}
